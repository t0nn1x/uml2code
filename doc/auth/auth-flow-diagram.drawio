                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n    subgraph \&quot;Traditional Authentication\&quot;\n        A1[User visits registration page] --&gt; A2[User submits registration form]\n        A2 --&gt; A3[System creates User entity]\n        A3 --&gt; A4[System sends verification email]\n        A4 --&gt; A5[User clicks verification link]\n        A5 --&gt; A6[System verifies email]\n        A6 --&gt; A7[User can log in]\n        \n        B1[User visits login page] --&gt; B2[User enters email/password]\n        B2 --&gt; B3[System authenticates user]\n        B3 --&gt; B4[User redirected to dashboard]\n    end\n    \n    subgraph \&quot;OAuth Authentication\&quot;\n        C1[User clicks social login button] --&gt; C2[User redirected to provider]\n        C2 --&gt; C3[User authorizes application]\n        C3 --&gt; C4[Provider redirects back with code]\n        C4 --&gt; C5[System exchanges code for token]\n        C5 --&gt; C6[System retrieves user info]\n        \n        C6 --&gt;|New user| C7[Creates new user account]\n        C6 --&gt;|Existing email| C8[Links OAuth to existing account]\n        C6 --&gt;|Existing OAuth| C9[Uses existing connection]\n        \n        C7 --&gt; C10[User redirected to dashboard]\n        C8 --&gt; C10\n        C9 --&gt; C10\n    end\n    \n    subgraph \&quot;Password Reset\&quot;\n        D1[User requests password reset] --&gt; D2[User enters email]\n        D2 --&gt; D3[System generates reset token]\n        D3 --&gt; D4[System sends reset email]\n        D4 --&gt; D5[User clicks reset link]\n        D5 --&gt; D6[User enters new password]\n        D6 --&gt; D7[System updates password]\n        D7 --&gt; D8[User redirected to login]\n    end&quot;&#xa;}" id="3">
