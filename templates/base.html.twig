<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}UML2Code{% endblock %}</title>
    
    <!-- Tailwind CSS -->
    <link rel="stylesheet" href="{{ asset('css/lib/tailwind.min.css') }}">
    
    <!-- Monaco Editor CSS -->
    <link rel="stylesheet" data-name="vs/editor/editor.main" href="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/editor/editor.main.css">
    
    <!-- Theme CSS -->
    <link rel="stylesheet" href="{{ asset('css/theme.css') }}">

    <!-- Custom CSS -->
    {% block stylesheets %}{% endblock %}
</head>
<body data-theme="light" class="min-h-screen flex flex-col bg-gray-50">
    <!-- Header -->
    <header class="bg-white shadow-sm border-b border-gray-200">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo -->
                <div class="flex items-center">
                    <a href="{{ path('app_home') }}" class="flex items-center">
                        <svg class="h-8 w-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                        </svg>
                        <span class="ml-2 text-xl font-semibold text-gray-900">UML2Code</span>
                    </a>
                </div>

                <!-- Navigation -->
                <div class="hidden md:flex items-center space-x-8">
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('app_converter') }}" class="text-gray-700 hover:text-indigo-600 px-3 py-2 rounded-md text-sm font-medium transition-colors">
                            {{ 'nav.converter'|trans }}
                        </a>
                        <a href="{{ path('app_uml_parser') }}" class="text-gray-700 hover:text-indigo-600 px-3 py-2 rounded-md text-sm font-medium transition-colors">
                            {{ 'nav.parser'|trans }}
                        </a>
                        <a href="{{ path('app_generator') }}" class="text-gray-700 hover:text-indigo-600 px-3 py-2 rounded-md text-sm font-medium transition-colors">
                            {{ 'nav.generator'|trans }}
                        </a>
                    {% endif %}
                </div>

                <!-- Right side items -->
                <div class="flex items-center space-x-4">
                    <!-- Language Switcher -->
                    <div class="relative">
                        <button id="language-switcher" class="flex items-center text-sm text-gray-700 hover:text-gray-900">
                            <svg class="h-5 w-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
                            </svg>
                            {{ app.request.locale|upper }}
                        </button>
                        <div id="language-menu" class="hidden absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5">
                            <div class="py-1">
                                <a href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({'_locale': 'en'})) }}" 
                                   class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                    🇬🇧 English
                                </a>
                                <a href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({'_locale': 'uk'})) }}" 
                                   class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                    🇺🇦 Українська
                                </a>
                            </div>
                        </div>
                    </div>
                    <button id="theme-toggle" class="text-gray-700 hover:text-gray-900 text-lg" aria-label="Toggle theme">🌙</button>

                    <!-- User Menu -->
                    {% if app.user %}
                        <div class="relative">
                            <button id="user-menu-button" class="flex items-center text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                                <div class="h-8 w-8 rounded-full bg-indigo-600 flex items-center justify-center text-white font-medium">
                                    {{ app.user.firstName|default(app.user.email)|first|upper }}
                                </div>
                            </button>
                            <div id="user-menu" class="hidden absolute right-0 mt-2 w-48 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5">
                                <div class="py-1">
                                    <a href="{{ path('app_dashboard') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                        {{ 'nav.dashboard'|trans }}
                                    </a>
                                    <button onclick="window.HistoryManager && window.HistoryManager.open('general')" class="w-full text-left block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                        {{ 'nav.history'|trans }}
                                    </button>
                                    <a href="{{ path('app_logout') }}" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                        {{ 'nav.logout'|trans }}
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-gray-700 hover:text-indigo-600 px-3 py-2 rounded-md text-sm font-medium">
                            {{ 'nav.login'|trans }}
                        </a>
                        <a href="{{ path('app_register') }}" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors">
                            {{ 'nav.register'|trans }}
                        </a>
                    {% endif %}

                    <!-- Mobile menu button -->
                    <button id="mobile-menu-button" class="md:hidden inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Mobile menu -->
            <div id="mobile-menu" class="hidden md:hidden">
                <div class="px-2 pt-2 pb-3 space-y-1">
                    {% if is_granted('ROLE_USER') %}
                        <a href="{{ path('app_converter') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">
                            {{ 'nav.converter'|trans }}
                        </a>
                        <a href="{{ path('app_uml_parser') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">
                            {{ 'nav.parser'|trans }}
                        </a>
                        <a href="{{ path('app_generator') }}" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">
                            {{ 'nav.generator'|trans }}
                        </a>
                    {% endif %}
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="md:flex md:justify-between">
                <div class="mb-8 md:mb-0">
                    <div class="flex items-center">
                        <svg class="h-8 w-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                        </svg>
                        <span class="ml-2 text-xl font-semibold text-gray-900">UML2Code</span>
                    </div>
                    <p class="mt-2 text-sm text-gray-500">
                        {{ 'footer.description'|trans }}
                    </p>
                </div>
                <div class="grid grid-cols-2 gap-8 md:grid-cols-3">
                    <div>
                        <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
                            {{ 'footer.features'|trans }}
                        </h3>
                        <ul class="mt-4 space-y-3">
                            <li>
                                <a href="{{ path('app_converter') }}" class="text-sm text-gray-500 hover:text-gray-900">
                                    {{ 'footer.converter'|trans }}
                                </a>
                            </li>
                            <li>
                                <a href="{{ path('app_uml_parser') }}" class="text-sm text-gray-500 hover:text-gray-900">
                                    {{ 'footer.parser'|trans }}
                                </a>
                            </li>
                            <li>
                                <a href="{{ path('app_generator') }}" class="text-sm text-gray-500 hover:text-gray-900">
                                    {{ 'footer.generator'|trans }}
                                </a>
                            </li>
                        </ul>
                    </div>
                    <div>
                        <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
                            {{ 'footer.account'|trans }}
                        </h3>
                        <ul class="mt-4 space-y-3">
                            {% if app.user %}
                                <li>
                                    <a href="{{ path('app_dashboard') }}" class="text-sm text-gray-500 hover:text-gray-900">
                                        {{ 'footer.dashboard'|trans }}
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_logout') }}" class="text-sm text-gray-500 hover:text-gray-900">
                                        {{ 'footer.logout'|trans }}
                                    </a>
                                </li>
                            {% else %}
                                <li>
                                    <a href="{{ path('app_login') }}" class="text-sm text-gray-500 hover:text-gray-900">
                                        {{ 'footer.login'|trans }}
                                    </a>
                                </li>
                                <li>
                                    <a href="{{ path('app_register') }}" class="text-sm text-gray-500 hover:text-gray-900">
                                        {{ 'footer.register'|trans }}
                                    </a>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                    <div>
                        <h3 class="text-sm font-semibold text-gray-400 tracking-wider uppercase">
                            {{ 'footer.languages'|trans }}
                        </h3>
                        <ul class="mt-4 space-y-3">
                            <li>
                                <a href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({'_locale': 'en'})) }}" 
                                   class="text-sm text-gray-500 hover:text-gray-900">
                                    🇬🇧 English
                                </a>
                            </li>
                            <li>
                                <a href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({'_locale': 'uk'})) }}" 
                                   class="text-sm text-gray-500 hover:text-gray-900">
                                    🇺🇦 Українська
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="mt-8 border-t border-gray-200 pt-8">
                <p class="text-sm text-gray-400 text-center">
                    © {{ 'now'|date('Y') }} UML2Code. {{ 'footer.rights'|trans }}
                </p>
            </div>
        </div>
    </footer>

    <!-- History Modal - available on all pages -->
    {% include 'history/moda.html.twig' %}

    <!-- Monaco Editor Loader -->
    <script src="https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs/loader.js"></script>
    
    <!-- Base JavaScript -->
    <script>
        // Language switcher dropdown
        document.getElementById('language-switcher').addEventListener('click', function() {
            document.getElementById('language-menu').classList.toggle('hidden');
        });

        // User menu dropdown
        const userMenuButton = document.getElementById('user-menu-button');
        if (userMenuButton) {
            userMenuButton.addEventListener('click', function() {
                document.getElementById('user-menu').classList.toggle('hidden');
            });
        }

        // Mobile menu toggle
        document.getElementById('mobile-menu-button').addEventListener('click', function() {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', function(event) {
            if (!event.target.closest('#language-switcher') && !event.target.closest('#language-menu')) {
                document.getElementById('language-menu').classList.add('hidden');
            }
            if (userMenuButton && !event.target.closest('#user-menu-button') && !event.target.closest('#user-menu')) {
                document.getElementById('user-menu').classList.add('hidden');
            }
        });

        // Monaco Editor configuration
        require.config({ paths: { 'vs': 'https://cdn.jsdelivr.net/npm/monaco-editor@0.45.0/min/vs' }});
        window.monacoTheme = localStorage.getItem("theme") === "dark" ? "vs-dark" : "vs-light";
        function applyTheme(theme) {
            document.body.setAttribute("data-theme", theme);
            localStorage.setItem("theme", theme);
            window.monacoTheme = theme === "dark" ? "vs-dark" : "vs-light";
            if (window.monaco && window.monaco.editor) {
                monaco.editor.setTheme(window.monacoTheme);
            }
            const tbtn = document.getElementById("theme-toggle");
            if (tbtn) {
            tbtn.textContent = theme === 'dark' ? '☀' : '🌙';
            }
        }

        document.addEventListener("DOMContentLoaded", function() {
            applyTheme(localStorage.getItem("theme") || "light");
            const tbtn = document.getElementById("theme-toggle");
            if (tbtn) {
                tbtn.addEventListener("click", function() {
                    const newTheme = document.body.getAttribute("data-theme") === "dark" ? "light" : "dark";
                    applyTheme(newTheme);
                });
            }
        });
    </script>

    <!-- JSZip for history export functionality -->
    <script src="{{ asset('js/lib/jszip-global.js') }}"></script>
    <script>
        // JSZip loader helper using event-based approach
        window.ensureJSZip = function() {
            return new Promise((resolve, reject) => {
                if (window.JSZip) {
                    resolve(window.JSZip);
                    return;
                }
                
                // Listen for JSZip ready event
                const timeout = setTimeout(() => {
                    reject(new Error('JSZip loading timeout'));
                }, 10000); // 10 second timeout
                
                const onReady = function(event) {
                    clearTimeout(timeout);
                    window.removeEventListener('jszipReady', onReady);
                    window.removeEventListener('jszipError', onError);
                    resolve(event.detail);
                };
                
                const onError = function(event) {
                    clearTimeout(timeout);
                    window.removeEventListener('jszipReady', onReady);
                    window.removeEventListener('jszipError', onError);
                    reject(new Error(event.detail));
                };
                
                window.addEventListener('jszipReady', onReady);
                window.addEventListener('jszipError', onError);
            });
        };
    </script>
    
    <!-- History management - available on all pages -->
    <script src="{{ asset('js/history.js') }}"></script>
    
    {% block javascripts %}{% endblock %}
</body>
</html>
