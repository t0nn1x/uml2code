{% extends 'admin/base.html.twig' %}

{% block content_title %}
    <h1 class="content-title">
        <i class="fas fa-cogs"></i>
        {{ 'log_management.title'|trans({}, 'admin') }}
    </h1>
{% endblock %}

{% block main %}
    <div class="row">
        <!-- Cleanup Status Card -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5><i class="fas fa-clock"></i> {{ 'log_management.auto_cleanup.title'|trans({}, 'admin') }}</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <td><strong>{{ 'log_management.auto_cleanup.status'|trans({}, 'admin') }}:</strong></td>
                            <td>
                                {% if cleanup_info.auto_cleanup_enabled %}
                                    <span class="badge badge-success">{{ 'log_management.auto_cleanup.enabled'|trans({}, 'admin') }}</span>
                                {% else %}
                                    <span class="badge badge-warning">{{ 'log_management.auto_cleanup.disabled'|trans({}, 'admin') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td><strong>{{ 'log_management.interval'|trans({}, 'admin') }}:</strong></td>
                            <td>{{ 'log_management.every_24_hours'|trans({}, 'admin') }}</td>
                        </tr>
                        <tr>
                            <td><strong>{{ 'log_management.auto_cleanup.last_run'|trans({}, 'admin') }}:</strong></td>
                            <td>
                                {% if cleanup_info.last_run %}
                                    {{ cleanup_info.last_run|date('Y-m-d H:i:s') }}
                                {% else %}
                                    <span class="text-muted">{{ 'status.never'|trans({}, 'admin') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td><strong>{{ 'log_management.next_scheduled'|trans({}, 'admin') }}:</strong></td>
                            <td>
                                {% if cleanup_info.next_scheduled %}
                                    {{ cleanup_info.next_scheduled|date('Y-m-d H:i:s') }}
                                {% else %}
                                    <span class="text-muted">{{ 'status.not_scheduled'|trans({}, 'admin') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <td><strong>{{ 'log_management.should_run_now'|trans({}, 'admin') }}:</strong></td>
                            <td>
                                {% if cleanup_info.should_run_now %}
                                    <span class="badge badge-warning">{{ 'status.yes'|trans({}, 'admin') }}</span>
                                {% else %}
                                    <span class="badge badge-success">{{ 'status.no'|trans({}, 'admin') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Log Statistics Card -->
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5><i class="fas fa-chart-bar"></i> {{ 'log_management.statistics.title'|trans({}, 'admin') }}</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <td><strong>{{ 'log_management.total_logs'|trans({}, 'admin') }}:</strong></td>
                            <td><span class="badge badge-info">{{ statistics.total_logs|number_format }}</span></td>
                        </tr>
                        <tr>
                            <td><strong>{{ 'log_management.old_logs'|trans({}, 'admin') }}:</strong></td>
                            <td><span class="badge badge-warning">{{ statistics.old_logs_count|number_format }}</span></td>
                        </tr>
                        <tr>
                            <td><strong>{{ 'log_management.retention_period'|trans({}, 'admin') }}:</strong></td>
                            <td>{{ statistics.retention_days }} {{ 'log_management.days'|trans({}, 'admin') }}</td>
                        </tr>
                        <tr>
                            <td><strong>{{ 'log_management.cutoff_date'|trans({}, 'admin') }}:</strong></td>
                            <td>{{ statistics.cutoff_date|date('Y-m-d H:i:s') }}</td>
                        </tr>
                        <tr>
                            <td><strong>{{ 'log_management.has_recent_errors'|trans({}, 'admin') }}:</strong></td>
                            <td>
                                {% if statistics.has_errors %}
                                    <span class="badge badge-danger">{{ 'status.yes'|trans({}, 'admin') }}</span>
                                {% else %}
                                    <span class="badge badge-success">{{ 'status.no'|trans({}, 'admin') }}</span>
                                {% endif %}
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Log Level Statistics -->
    {% if statistics.statistics_by_level %}
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-layer-group"></i> {{ 'log_management.logs_by_level'|trans({}, 'admin') }}</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        {% for stat in statistics.statistics_by_level %}
                            <div class="col-md-3 mb-3">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h4 class="card-title">{{ stat.count|number_format }}</h4>
                                        <p class="card-text">
                                            <span class="badge badge-{% if stat.level in ['error', 'critical', 'alert', 'emergency'] %}danger{% elseif stat.level == 'warning' %}warning{% elseif stat.level == 'info' %}success{% else %}secondary{% endif %}">
                                                {{ ('system_logs.levels.' ~ stat.level)|trans({}, 'admin')|upper }}
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Manual Cleanup Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5><i class="fas fa-tools"></i> {{ 'log_management.manual_cleanup_actions'|trans({}, 'admin') }}</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>{{ 'log_management.custom_cleanup'|trans({}, 'admin') }}</h6>
                            <p class="text-muted">{{ 'log_management.clean_logs_older_than'|trans({}, 'admin') }}</p>
                            <form id="manualCleanupForm">
                                <div class="input-group mb-3">
                                    <input type="number" class="form-control" id="retentionDays" 
                                           placeholder="{{ 'log_management.days_to_keep'|trans({}, 'admin') }}" value="{{ statistics.retention_days }}" min="1" max="365">
                                    <div class="input-group-append">
                                        <button class="btn btn-warning btn-lg" type="submit" style="height: calc(1.5em + 0.75rem + 2px); line-height: 1.5;">
                                            <i class="fas fa-trash"></i> {{ 'log_management.clean_logs'|trans({}, 'admin') }}
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="col-md-6">
                            <h6>{{ 'log_management.force_auto_cleanup'|trans({}, 'admin') }}</h6>
                            <p class="text-muted">{{ 'log_management.run_automatic_cleanup_now'|trans({}, 'admin') }}</p>
                            <div class="mb-3">
                                <button id="forceCleanupBtn" class="btn btn-danger btn-lg" style="height: calc(1.5em + 0.75rem + 2px); line-height: 1.5;">
                                    <i class="fas fa-bolt"></i> {{ 'log_management.force_cleanup_now'|trans({}, 'admin') }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cleanup Results -->
    <div class="row mt-4" id="cleanupResults" style="display: none;">
        <div class="col-12">
            <div class="card" id="resultsCard">
                <div class="card-header">
                    <h5><i class="fas fa-check-circle"></i> Cleanup Results</h5>
                </div>
                <div class="card-body" id="resultsBody">
                    <!-- Results will be populated by JavaScript -->
                </div>
            </div>
        </div>
    </div>

    <!-- Cleanup Schedule Information -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5><i class="fas fa-info-circle"></i> Automatic Cleanup Information</h5>
                </div>
                <div class="card-body">
                    <h6>How it works:</h6>
                    <ul>
                        <li><strong>Trigger:</strong> Automatic cleanup runs after certain routes are accessed (admin panel, dashboard, main app features)</li>
                        <li><strong>Frequency:</strong> Maximum once every {{ cleanup_info.cleanup_interval_hours }} hours</li>
                        <li><strong>Conditions:</strong> Only runs when there are more than 1,000 old logs OR total logs exceed 10,000</li>
                        <li><strong>Default Retention:</strong> Logs older than {{ statistics.retention_days }} days are removed</li>
                    </ul>
                    
                    <h6 class="mt-3">Manual Setup (Optional):</h6>
                    <p>For guaranteed cleanup scheduling, add this to your crontab:</p>
                    <code>0 2 * * * /path/to/php /path/to/bin/console app:auto-cleanup-logs --force</code>
                    <p class="text-muted mt-2">This runs daily at 2 AM and forces cleanup regardless of thresholds.</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Manual cleanup form
            const manualForm = document.getElementById('manualCleanupForm');
            const forceBtn = document.getElementById('forceCleanupBtn');
            const resultsDiv = document.getElementById('cleanupResults');
            const resultsCard = document.getElementById('resultsCard');
            const resultsBody = document.getElementById('resultsBody');

            function showResults(data, isSuccess) {
                resultsCard.className = 'card border-' + (isSuccess ? 'success' : 'danger');
                resultsBody.innerHTML = `
                    <div class="alert alert-${isSuccess ? 'success' : 'danger'}">
                        <strong>${isSuccess ? 'Success!' : 'Error!'}</strong> ${data.message}
                    </div>
                    ${data.deleted_count !== undefined ? `
                        <p><strong>Deleted logs:</strong> ${data.deleted_count.toLocaleString()}</p>
                        <p><strong>Retention period:</strong> ${data.retention_days} days</p>
                    ` : ''}
                `;
                resultsDiv.style.display = 'block';
                resultsDiv.scrollIntoView({ behavior: 'smooth' });
            }

            manualForm.addEventListener('submit', function(e) {
                e.preventDefault();
                const retentionDays = document.getElementById('retentionDays').value;
                
                if (!retentionDays || retentionDays <= 0) {
                    alert('Please enter a valid number of days');
                    return;
                }

                const btn = this.querySelector('button[type="submit"]');
                const originalText = btn.innerHTML;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Cleaning...';
                btn.disabled = true;

                const formData = new FormData();
                formData.append('retention_days', retentionDays);

                fetch('{{ path('admin_logs_cleanup') }}', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    showResults(data, data.success);
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                })
                .catch(error => {
                    showResults({message: 'Network error: ' + error.message}, false);
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                });
            });

            forceBtn.addEventListener('click', function() {
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Running...';
                this.disabled = true;

                fetch('{{ path('admin_logs_force_cleanup') }}', {
                    method: 'POST'
                })
                .then(response => response.json())
                .then(data => {
                    showResults(data, data.success);
                    this.innerHTML = originalText;
                    this.disabled = false;
                })
                .catch(error => {
                    showResults({message: 'Network error: ' + error.message}, false);
                    this.innerHTML = originalText;
                    this.disabled = false;
                });
            });
        });
    </script>
{% endblock %} 
