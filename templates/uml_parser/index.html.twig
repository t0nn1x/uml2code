{% extends 'base.html.twig' %}

{% block title %}{{ 'parser.title'|trans }} - UML2Code{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-indigo-500 to-purple-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-2xl font-bold text-white">{{ 'parser.title'|trans }}</h1>
                    <p class="text-indigo-100 text-sm mt-1">{{ 'parser.subtitle'|trans }}</p>
                </div>
                <button onclick="window.HistoryManager && window.HistoryManager.open('parser')" class="bg-white bg-opacity-20 hover:bg-opacity-30 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors">
                    <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    {{ 'history.button'|trans }}
                </button>
            </div>
        </div>

        <!-- Content -->
        <div class="p-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Input Section -->
                <div class="space-y-4">
                    <div class="flex justify-between items-center mb-2">
                        <label class="block text-sm font-medium text-gray-700">
                            {{ 'parser.input_label'|trans }}
                        </label>
                        <button id="import-puml-btn" class="text-sm text-indigo-600 hover:text-indigo-500 flex items-center">
                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                            </svg>
                            {{ 'common.import_puml_file'|trans }}
                        </button>
                    </div>
                    
                    <div id="uml-editor" class="border border-gray-300 rounded-md" style="height: 400px;"></div>
                    <input type="file" id="puml-file-input" accept=".puml,.plantuml,.txt" class="hidden">

                    <!-- Parse Button -->
                    <button id="parse-button" class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-200 flex items-center justify-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        {{ 'parser.parse_button'|trans }}
                    </button>
                </div>

                <!-- Output Section -->
                <div class="space-y-4">
                    <div class="flex justify-between items-center mb-2">
                        <label class="block text-sm font-medium text-gray-700">
                            {{ 'parser.output_label'|trans }}
                        </label>
                        <div class="flex items-center">
                            <button id="copy-button" class="text-sm text-indigo-600 hover:text-indigo-500 hidden">
                                {{ 'common.copy'|trans }}
                            </button>
                        </div>
                    </div>
                    
                    <div id="output-container" class="border border-gray-300 rounded-md overflow-hidden" style="height: 400px;">
                        <div id="output-placeholder" class="flex items-center justify-center h-full text-gray-500 bg-gray-50">
                            {{ 'parser.output_placeholder'|trans }}
                        </div>
                        <div id="loading" class="hidden flex items-center justify-center h-full bg-gray-50">
                            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
                        </div>
                        <div id="results" class="hidden h-full">
                            <div id="json-editor" class="h-full"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Error Alert -->
            <div id="error" class="mt-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md hidden">
                <div class="flex">
                    <svg class="h-5 w-5 text-red-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                    </svg>
                    <span id="error-message"></span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
require(['vs/editor/editor.main'], function() {
    // Wait for PlantUML registration before creating editor
    function createUMLEditor() {
        if (window.isPlantUMLRegistered && window.isPlantUMLRegistered()) {
            const currentTheme = localStorage.getItem("theme") === "dark" ? "dark" : "light";
            const plantumlTheme = window.getPlantUMLTheme ? window.getPlantUMLTheme(currentTheme === "dark") : 
                                 (currentTheme === "dark" ? 'plantuml-dark' : 'plantuml-light');
            
            // Initialize UML editor with PlantUML syntax highlighting
            const umlEditor = monaco.editor.create(document.getElementById('uml-editor'), {
                value: `@startuml
class User {
    +id: int
    -password: string
    +login(password: string): bool
}

class Order {
    +id: int
    +date: DateTime
    +calculateTotal(): float
}

User "1" --> "*" Order: places
@enduml`,
                language: 'plantuml',
                theme: plantumlTheme,
                minimap: { enabled: false },
                automaticLayout: true,
                fontSize: 13,
                lineNumbers: 'on',
                wordWrap: 'on',
                scrollBeyondLastLine: false
            });
            
            // Store editor reference for theme updates
            window.umlEditor = umlEditor;
            
            initializeEventHandlers();
        } else {
            // Retry after a short delay
            setTimeout(createUMLEditor, 100);
        }
    }
    
    function initializeEventHandlers() {

    // Handle PUML file import
    const importBtn = document.getElementById('import-puml-btn');
    const fileInput = document.getElementById('puml-file-input');
    
    importBtn.addEventListener('click', function() {
        fileInput.click();
    });
    
    fileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            // Check file extension
            const validExtensions = ['.puml', '.plantuml', '.txt'];
            const fileExtension = file.name.toLowerCase().substring(file.name.lastIndexOf('.'));
            
            if (!validExtensions.includes(fileExtension)) {
                showError('{{ 'import.error.invalid_puml_file'|trans }}');
                return;
            }
            
            // Check file size (max 1MB)
            if (file.size > 1024 * 1024) {
                showError('{{ 'import.error.file_too_large'|trans }}');
                return;
            }
            
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const content = e.target.result;
                    // Set the content in the Monaco editor
                    window.umlEditor.setValue(content);
                    
                    // Clear any errors
                    hideError();
                    
                    // Show success feedback
                    const originalText = importBtn.textContent;
                    importBtn.innerHTML = '<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>{{ 'common.file_imported'|trans }}';
                    importBtn.classList.add('text-green-600');
                    
                    setTimeout(() => {
                        importBtn.innerHTML = '<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path></svg>{{ 'common.import_puml_file'|trans }}';
                        importBtn.classList.remove('text-green-600');
                    }, 2000);
                    
                } catch (error) {
                    showError('{{ 'import.error.read_error'|trans }}: ' + error.message);
                }
            };
            
            reader.onerror = function() {
                showError('{{ 'import.error.read_error'|trans }}');
            };
            
            reader.readAsText(file);
        }
        
        // Reset file input
        fileInput.value = '';
    });

    // Initialize JSON editor (for output)
    let jsonEditor = null;

    const parseButton = document.getElementById('parse-button');
    const resultsDiv = document.getElementById('results');
    const loadingDiv = document.getElementById('loading');
    const errorDiv = document.getElementById('error');
    const errorMessage = document.getElementById('error-message');
    const copyButton = document.getElementById('copy-button');
    const outputPlaceholder = document.getElementById('output-placeholder');

    // Copy results functionality
    copyButton.addEventListener('click', function() {
        if (jsonEditor) {
            const content = jsonEditor.getValue();
            navigator.clipboard.writeText(content).then(() => {
                const originalText = copyButton.textContent;
                copyButton.textContent = '{{ 'common.copied'|trans }}';
                copyButton.classList.add('text-green-600');
                setTimeout(() => {
                    copyButton.textContent = originalText;
                    copyButton.classList.remove('text-green-600');
                }, 2000);
            });
        }
    });

    parseButton.addEventListener('click', function() {
        const umlCode = umlEditor.getValue().trim();

        if (!umlCode) {
            showError('{{ 'parser.error.empty_uml'|trans }}');
            return;
        }

        // Show loading, hide results and errors
        outputPlaceholder.classList.add('hidden');
        loadingDiv.classList.remove('hidden');
        resultsDiv.classList.add('hidden');
        copyButton.classList.add('hidden');
        hideError();

        // Make API request
        fetch('/api/uml/parse', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({uml: umlCode})
        })
        .then(response => response.json())
        .then(data => {
            loadingDiv.classList.add('hidden');

            if (data.success === false) {
                showError(data.error || '{{ 'parser.error.parsing_failed'|trans }}');
                outputPlaceholder.classList.remove('hidden');
                return;
            }

            // Create or update JSON editor
            if (jsonEditor) {
                jsonEditor.dispose();
            }
            
            setTimeout(() => {
                jsonEditor = monaco.editor.create(document.getElementById('json-editor'), {
                    value: JSON.stringify(data, null, 2),
                    language: 'json',
                    theme: window.monacoTheme,
                    readOnly: true,
                    minimap: { enabled: false },
                    automaticLayout: true,
                    fontSize: 13,
                    lineNumbers: 'on',
                    wordWrap: 'on',
                    scrollBeyondLastLine: false
                });
                
                // Store reference globally for theme updates
                window.jsonEditor = jsonEditor;
            }, 100);

            resultsDiv.classList.remove('hidden');
            copyButton.classList.remove('hidden');
        })
        .catch(error => {
            loadingDiv.classList.add('hidden');
            showError('Network error: ' + error.message);
            outputPlaceholder.classList.remove('hidden');
        });
    });

    // Error handling
    function showError(message) {
        errorMessage.textContent = message;
        errorDiv.classList.remove('hidden');
    }

    function hideError() {
        errorDiv.classList.add('hidden');
    }
    
    } // End of initializeEventHandlers function
    
    // Start the initialization process
    createUMLEditor();
});
</script>
{% endblock %}
