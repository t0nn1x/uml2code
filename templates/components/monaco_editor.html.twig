{# templates/components/monaco_editor.html.twig #}
<div class="monaco-editor-wrapper">
    {% if showToolbar %}
    <div class="monaco-editor-toolbar">
        {% if languages|length > 0 %}
        <select class="language-selector" data-editor-id="{{ id }}">
            {% for lang in languages %}
            <option value="{{ lang.value }}" {% if language == lang.value %}selected{% endif %}>{{ lang.label }}</option>
            {% endfor %}
        </select>
        {% endif %}
        <button class="copy-btn" data-editor-id="{{ id }}">Copy</button>
    </div>
    {% endif %}
    
    <div class="monaco-editor-content">
        <div id="{{ id }}" class="monaco-editor-container {{ size }} bg-gray-900"></div>
        
        {% if formField %}
        <input type="hidden" name="{{ formField }}" id="{{ formField }}" value="{{ content|e }}">
        {% endif %}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Wait for Monaco to be loaded
    require(['vs/editor/editor.main'], function() {
        // Set editor theme based on current site theme
        const isDarkMode = document.documentElement.classList.contains('dark') || 
                           localStorage.getItem('color-theme') === 'dark' ||
                           (!localStorage.getItem('color-theme') && 
                            window.matchMedia('(prefers-color-scheme: dark)').matches);
        
        // Define custom editor themes
        monaco.editor.defineTheme('uml2code-dark', {
            base: 'vs-dark',
            inherit: true,
            rules: [
                { token: 'keyword', foreground: '569CD6', fontStyle: 'bold' },
                { token: 'type', foreground: '4EC9B0' },
                { token: 'string', foreground: 'CE9178' },
                { token: 'number', foreground: 'B5CEA8' },
                { token: 'comment', foreground: '6A9955' },
                { token: 'operator', foreground: 'D4D4D4' },
                { token: 'delimiter', foreground: 'FFFFFF' }
            ],
            colors: {
                'editor.background': '#1E1E1E',
                'editor.foreground': '#D4D4D4',
                'editorLineNumber.foreground': '#858585',
                'editorLineNumber.activeForeground': '#C6C6C6',
                'editor.selectionBackground': '#264F78',
                'editor.lineHighlightBackground': '#2D2D30',
                'editor.lineHighlightBorder': '#383838'
            }
        });
        
        // Create editor with provided options
        const options = {{ options|json_encode|raw }};
        
        // If readOnly is true, add it to options
        {% if readOnly %}
        options.readOnly = true;
        {% endif %}
        
        // Set the theme based on current site theme
        options.theme = 'uml2code-dark';
        
        // Initialize the editor
        const editor = window.monacoEditorManager.createEditor('{{ id }}', '{{ language }}', {{ content|json_encode|raw }}, options);
        
        // Handle form submission if there's a form field
        {% if formField %}
        const formField = document.getElementById('{{ formField }}');
        if (formField && editor) {
            editor.onDidChangeModelContent(function() {
                formField.value = editor.getValue();
            });
        }
        {% endif %}
        
        // Set up language selector if available
        const languageSelector = document.querySelector('.language-selector[data-editor-id="{{ id }}"]');
        if (languageSelector) {
            languageSelector.addEventListener('change', function() {
                window.monacoEditorManager.setLanguage('{{ id }}', this.value);
            });
        }
        
        // Set up copy button if available
        const copyBtn = document.querySelector('.copy-btn[data-editor-id="{{ id }}"]');
        if (copyBtn) {
            copyBtn.addEventListener('click', function() {
                const content = window.monacoEditorManager.getContent('{{ id }}');
                navigator.clipboard.writeText(content).then(function() {
                    copyBtn.textContent = 'Copied!';
                    setTimeout(function() {
                        copyBtn.textContent = 'Copy';
                    }, 2000);
                });
            });
        }
        
        // Update on theme changes
        const themeToggleBtn = document.getElementById('theme-toggle');
        if (themeToggleBtn) {
            themeToggleBtn.addEventListener('click', function() {
                // We don't need to change Monaco's theme as we're using a fixed dark theme
            });
        }
    });
});
</script> 
