{% extends 'base.html.twig' %}

{% block title %}Email Confirmation - UML2Code
{% endblock %}

{% block body %}
	<div class="bg-gray-100 min-h-screen flex flex-col">
		<div class="bg-white p-6 shadow">
			<h1 class="text-2xl font-bold text-indigo-600">UML2Code</h1>
		</div>

		<div class="flex-grow flex items-center justify-center p-6">
			<div class="max-w-lg w-full bg-white rounded-lg shadow-md p-8">
				<h2 class="text-xl font-bold text-gray-800 mb-6">Confirm your email address</h2>

				<p class="text-gray-600 mb-6">
					Hi
					{{ user is defined and user.firstName ? user.firstName : 'there' }},

				</p>

				<p class="text-gray-600 mb-6">
					Welcome to UML2Code! Please confirm your email address by clicking the button below.
										                This ensures we have the right email in case you need to reset your password or receive notifications.
				</p>

				<div class="bg-gray-50 p-4 rounded-md border border-gray-200 text-center mb-6">
					<a href="{{ signedUrl }}" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-6 py-3 rounded-md">
						Confirm Email
					</a>
				</div>

				<p class="text-gray-600 mb-2">
					This confirmation link will expire in
					{{ expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle') }}.
				</p>

				<p class="text-gray-600 mb-6">
					If you didn't create an account with us, you can safely ignore this email.
				</p>

				<p class="text-gray-600">
					Best regards,<br>
					The UML2Code Team
				</p>
			</div>
		</div>
	</div>
{% endblock %}
