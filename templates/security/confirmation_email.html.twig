{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.confirmation.title'|trans }}
{% endblock %}

{% block body %}
	<div class="bg-gray-100 min-h-screen flex flex-col">
		<div class="bg-white p-6 shadow">
			<h1 class="text-2xl font-bold text-indigo-600">UML2Code</h1>
		</div>

		<div class="flex-grow flex items-center justify-center p-6">
			<div class="max-w-lg w-full bg-white rounded-lg shadow-md p-8">
				<h2 class="text-xl font-bold text-gray-800 mb-6">{{ 'auth.confirmation.heading'|trans }}</h2>

				<p class="text-gray-600 mb-6">
					{% if user is defined and user.firstName %}
						{{ 'auth.confirmation.greeting'|trans({'%name%': user.firstName}) }},
					{% else %}
						{{ 'auth.confirmation.greeting_default'|trans }},
					{% endif %}
				</p>

				<p class="text-gray-600 mb-6">
					{{ 'auth.confirmation.welcome_message'|trans }}
					{{ 'auth.confirmation.purpose_message'|trans }}
				</p>

				<div class="bg-gray-50 p-4 rounded-md border border-gray-200 text-center mb-6">
					<a href="{{ signedUrl }}" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-medium px-6 py-3 rounded-md">
						{{ 'auth.confirmation.confirm_button'|trans }}
					</a>
				</div>

				<p class="text-gray-600 mb-2">
					{{ 'auth.confirmation.expire_notice'|trans({'%time%': expiresAtMessageKey|trans(expiresAtMessageData, 'VerifyEmailBundle')}) }}
				</p>

				<p class="text-gray-600 mb-6">
					{{ 'auth.confirmation.ignore_notice'|trans }}
				</p>

				<p class="text-gray-600">
					{{ 'auth.confirmation.best_regards'|trans }},<br>
					{{ 'auth.confirmation.team_signature'|trans }}
				</p>
			</div>
		</div>
	</div>
{% endblock %}
