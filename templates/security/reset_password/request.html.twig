{% extends 'base.html.twig' %}

{% block title %}Reset your password - UML2Code
{% endblock %}

{% block body %}
	<div class="min-h-screen flex items-center justify-center bg-gray-100 py-12 px-4 sm:px-6 lg:px-8">
		<div class="max-w-md w-full space-y-8">
			<div>
				<h1 class="text-center text-3xl font-extrabold text-indigo-600">UML2Code</h1>
				<h2 class="mt-6 text-center text-2xl font-bold text-gray-900">Reset your password</h2>
			</div>

			{% for flash_error in app.flashes('reset_password_error') %}
				<div class="rounded-md bg-red-50 p-4 my-4">
					<div class="flex">
						<div class="flex-shrink-0">
							<svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 20 20" fill="currentColor" aria-hidden="true">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
							</svg>
						</div>
						<div class="ml-3">
							<p class="text-sm font-medium text-red-800">{{ flash_error }}</p>
						</div>
					</div>
				</div>
			{% endfor %}

			<div class="rounded-md shadow-sm -space-y-px bg-white">
				<div class="px-6 py-6">
					{{ form_start(requestForm, {'attr': {'class': 'space-y-6'}}) }}
					<div>
						<p class="text-sm text-gray-700 mb-4">Enter your email address and we'll send you a link to reset your password.</p>

						{{ form_label(requestForm.email, 'Email address', {'label_attr': {'class': 'block text-sm font-medium text-gray-700'}}) }}
						<div class="mt-1">
							{{ form_widget(requestForm.email) }}
							{{ form_errors(requestForm.email) }}
						</div>
					</div>

					<div>
						<button type="submit" class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
							Send password reset email
						</button>
					</div>
					{{ form_end(requestForm) }}
				</div>
			</div>
		</div>
	</div>
{% endblock %}
