{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.reset_password.check_email.title'|trans }}{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center bg-gray-100 py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full space-y-8">
            <div>
                <h1 class="text-center text-3xl font-extrabold text-indigo-600">UML2Code</h1>
                <h2 class="mt-6 text-center text-2xl font-bold text-gray-900">{{ 'auth.reset_password.check_email.heading'|trans }}</h2>
            </div>

            <div class="rounded-md shadow-sm bg-white p-6">
                <div class="text-sm text-gray-700 space-y-4">
                    <p>
                        {{ 'auth.reset_password.check_email.message'|trans({'%time%': resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle')}) }}
                    </p>
                    <p>
                        {{ 'auth.reset_password.check_email.no_email'|trans }}
                        <a href="{{ path('app_forgot_password_request') }}" class="text-indigo-600 hover:text-indigo-500">{{ 'auth.reset_password.check_email.try_again'|trans }}</a>.
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
