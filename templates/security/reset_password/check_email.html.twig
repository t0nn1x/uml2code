{% extends 'base.html.twig' %}

{% block title %}Password Reset Email Sent - UML2Code{% endblock %}

{% block body %}
    <div class="min-h-screen flex items-center justify-center bg-gray-100 py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full space-y-8">
            <div>
                <h1 class="text-center text-3xl font-extrabold text-indigo-600">UML2Code</h1>
                <h2 class="mt-6 text-center text-2xl font-bold text-gray-900">Check your email</h2>
            </div>

            <div class="rounded-md shadow-sm bg-white p-6">
                <div class="text-sm text-gray-700 space-y-4">
                    <p>
                        If an account matching your email exists, then an email was just sent that contains a link that you can use to reset your password.
                        This link will expire in {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
                    </p>
                    <p>
                        If you don't receive an email please check your spam folder or 
                        <a href="{{ path('app_forgot_password_request') }}" class="text-indigo-600 hover:text-indigo-500">try again</a>.
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
