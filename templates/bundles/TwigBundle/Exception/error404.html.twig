{% extends 'base.html.twig' %}

{% block title %}{{ 'error.404.title'|trans }} - {{ parent() }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-indigo-50 to-blue-100 flex items-center justify-center px-4">
    <div class="max-w-2xl mx-auto text-center">
        <!-- Error Code -->
        <div class="mb-8">
            <h1 class="text-9xl font-bold text-indigo-600 mb-4">404</h1>
            <div class="w-32 h-1 bg-indigo-600 mx-auto rounded-full"></div>
        </div>

        <!-- Error Message -->
        <div class="mb-8">
            <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-4">
                {{ 'error.404.heading'|trans|default('Page Not Found') }}
            </h2>
            <p class="text-lg text-gray-600 dark:text-gray-300 mb-6">
                {{ 'error.404.message'|trans|default('The page you are looking for might have been removed, had its name changed, or is temporarily unavailable.') }}
            </p>
        </div>

        <!-- Visual Element -->
        <div class="mb-8">
            <div class="w-48 h-48 mx-auto bg-indigo-100 dark:bg-indigo-900 rounded-full flex items-center justify-center">
                <!-- Search icon from Heroicons -->
                <svg class="w-24 h-24 text-indigo-600 dark:text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="{{ path('app_home') }}" 
               class="inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                {{ 'error.go_home'|trans|default('Go Home') }}
            </a>
            
            <button onclick="history.back()" 
                    class="inline-flex items-center px-6 py-3 border border-gray-300 text-base font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                {{ 'error.go_back'|trans|default('Go Back') }}
            </button>
        </div>

        <!-- Helpful Links -->
        {% if is_granted('ROLE_USER') %}
                 <div class="mt-6 pt-4 border-t border-indigo-200 dark:border-indigo-700 mb-12">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-4">
                {{ 'error.helpful_links'|trans|default('Helpful Links') }}
            </h3>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <a href="{{ path('app_converter') }}" 
                   class="p-4 bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-shadow border border-gray-200 dark:border-gray-700">
                    <div class="text-indigo-600 dark:text-indigo-400 mb-2">
                        <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-900 dark:text-gray-100">{{ 'nav.converter'|trans }}</p>
                </a>
                
                <a href="{{ path('app_uml_parser') }}" 
                   class="p-4 bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-shadow border border-gray-200 dark:border-gray-700">
                    <div class="text-indigo-600 dark:text-indigo-400 mb-2">
                        <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-900 dark:text-gray-100">{{ 'nav.parser'|trans }}</p>
                </a>
                
                <a href="{{ path('app_generator') }}" 
                   class="p-4 bg-white dark:bg-gray-800 rounded-lg shadow-sm hover:shadow-md transition-shadow border border-gray-200 dark:border-gray-700">
                    <div class="text-indigo-600 dark:text-indigo-400 mb-2">
                        <svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-900 dark:text-gray-100">{{ 'nav.generator'|trans }}</p>
                </a>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %} 
