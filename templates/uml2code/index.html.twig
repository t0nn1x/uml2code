{% extends 'base.html.twig' %}

{% block title %}Code Generator{% endblock %}

{% block stylesheets %}
<style>
    .json-editor {
        min-height: 300px;
        font-family: monospace;
        resize: vertical;
    }
    
    .results {
        max-height: 600px;
        overflow-y: auto;
    }
    
    .code-file {
        margin-bottom: 1rem;
        background-color: #f5f5f5;
        border-radius: 0.375rem;
        padding: 0.5rem;
    }
    
    .file-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem;
        background-color: #e0e0e0;
        border-radius: 0.25rem;
        margin-bottom: 0.5rem;
    }
    
    .file-content {
        padding: 0.5rem;
        white-space: pre-wrap;
        font-family: monospace;
        font-size: 0.875rem;
    }
    
    .spinner {
        display: inline-block;
        width: 1.5rem;
        height: 1.5rem;
        border-radius: 50%;
        border: 2px solid #ccc;
        border-top-color: #3b82f6;
        animation: spinner 0.8s linear infinite;
    }
    
    @keyframes spinner {
        to {
            transform: rotate(360deg);
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col bg-gray-100">
    <header class="bg-white shadow">
        <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
            <h1 class="text-3xl font-bold text-gray-900">Code Generator</h1>
            <p class="mt-1 text-sm text-gray-500">Generate code from JSON class diagram</p>
        </div>
    </header>

    <main class="flex-grow">
        <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
            <div class="px-4 py-6 sm:px-0">
                <div class="bg-white overflow-hidden shadow rounded-lg divide-y divide-gray-200">
                    <!-- Input Section -->
                    <div class="px-4 py-5 sm:p-6">
                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 mb-4">
                            <div>
                                <label for="language-select" class="block text-sm font-medium text-gray-700">
                                    Programming Language
                                </label>
                                <select id="language-select" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
                                    <option value="">Select language...</option>
                                    {% for language, versions in supported_languages %}
                                        <option value="{{ language }}">{{ language }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div>
                                <label for="version-select" class="block text-sm font-medium text-gray-700">
                                    Language Version
                                </label>
                                <select id="version-select" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
                                    <option value="">Select version...</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="json-input" class="block text-sm font-medium text-gray-700">
                                UML Diagram (JSON)
                            </label>
                            <textarea id="json-input" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 json-editor" rows="10" placeholder="Paste your UML JSON here..."></textarea>
                        </div>

                        <div class="flex justify-end">
                            <button id="generate-button" type="button" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                                Generate Code
                            </button>
                        </div>
                    </div>

                    <!-- Results Section -->
                    <div class="px-4 py-5 sm:p-6">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-lg font-medium leading-6 text-gray-900">Generated Code</h3>
                            <button id="copy-all-button" type="button" class="inline-flex items-center px-3 py-1 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 hidden">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                                </svg>
                                Copy All
                            </button>
                        </div>
                        
                        <div id="loading" class="mt-4 hidden">
                            <div class="flex justify-center items-center space-x-2">
                                <div class="spinner"></div>
                                <span>Generating code...</span>
                            </div>
                        </div>
                        
                        <div id="error" class="mt-4 bg-red-50 p-4 rounded-md hidden">
                            <div class="flex">
                                <div class="flex-shrink-0">
                                    <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                    </svg>
                                </div>
                                <div class="ml-3">
                                    <h3 class="text-sm font-medium text-red-800" id="error-message">Error generating code</h3>
                                </div>
                            </div>
                        </div>
                        
                        <div id="generated-code" class="mt-4 results hidden">
                            <div id="file-container" class="space-y-4"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const generateButton = document.getElementById('generate-button');
    const jsonInput = document.getElementById('json-input');
    const loadingDiv = document.getElementById('loading');
    const errorDiv = document.getElementById('error');
    const errorMessage = document.getElementById('error-message');
    const copyAllButton = document.getElementById('copy-all-button');
    const languageSelect = document.getElementById('language-select');
    const versionSelect = document.getElementById('version-select');
    const generatedCodeDiv = document.getElementById('generated-code');
    const fileContainer = document.getElementById('file-container');
    
    // Store the supported languages
    const supportedLanguages = {
        {% for language, versions in supported_languages %}
            "{{ language }}": {{ versions|json_encode|raw }},
        {% endfor %}
    };
    
    // Add event listener for language selection
    languageSelect.addEventListener('change', function() {
        const language = this.value;
        // Clear version select
        while (versionSelect.options.length > 1) {
            versionSelect.remove(1);
        }
        
        if (language && supportedLanguages[language]) {
            // Add version options
            supportedLanguages[language].forEach(version => {
                const option = document.createElement('option');
                option.value = version;
                option.textContent = version;
                versionSelect.appendChild(option);
            });
            
            // Select the first version by default
            if (supportedLanguages[language].length > 0) {
                versionSelect.value = supportedLanguages[language][0];
            }
        }
    });
    
    // Copy all generated code
    copyAllButton.addEventListener('click', function() {
        const fileElements = fileContainer.querySelectorAll('.code-file');
        const files = {};
        
        fileElements.forEach(fileElement => {
            const filename = fileElement.querySelector('.file-name').textContent;
            const content = fileElement.querySelector('.file-content').textContent;
            files[filename] = content;
        });
        
        const textToCopy = Object.entries(files).map(([filename, content]) => {
            return `// ${filename}\n${content}\n`;
        }).join('\n');
        
        navigator.clipboard.writeText(textToCopy).then(() => {
            // Temporarily change button text to show success
            const originalText = copyAllButton.innerHTML;
            copyAllButton.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Copied!
            `;
            copyAllButton.classList.remove('text-gray-700', 'bg-white', 'hover:bg-gray-50');
            copyAllButton.classList.add('text-green-700', 'bg-green-50', 'hover:bg-green-100');
            
            setTimeout(() => {
                copyAllButton.innerHTML = originalText;
                copyAllButton.classList.remove('text-green-700', 'bg-green-50', 'hover:bg-green-100');
                copyAllButton.classList.add('text-gray-700', 'bg-white', 'hover:bg-gray-50');
            }, 2000);
        }).catch(err => {
            console.error('Failed to copy text: ', err);
        });
    });
    
    // Generate code
    generateButton.addEventListener('click', function() {
        const jsonCode = jsonInput.value.trim();
        const language = languageSelect.value;
        const version = versionSelect.value;
        
        if (!jsonCode) {
            errorDiv.classList.remove('hidden');
            errorMessage.textContent = 'Please enter some JSON diagram code';
            return;
        }
        
        if (!language) {
            errorDiv.classList.remove('hidden');
            errorMessage.textContent = 'Please select a target language';
            return;
        }
        
        // Validate JSON
        let parsedJson;
        try {
            parsedJson = JSON.parse(jsonCode);
        } catch (e) {
            errorDiv.classList.remove('hidden');
            errorMessage.textContent = 'Invalid JSON: ' + e.message;
            return;
        }
        
        // Show loading, hide errors
        loadingDiv.classList.remove('hidden');
        errorDiv.classList.add('hidden');
        generatedCodeDiv.classList.add('hidden');
        copyAllButton.classList.add('hidden');
        
        // Make API request to generate code
        fetch('/api/generator/generate', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                diagram: parsedJson,
                language: language,
                version: version
            })
        })
        .then(response => {
            if (!response.ok) {
                throw new Error(`HTTP error! Status: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            loadingDiv.classList.add('hidden');
            
            if (data.success === false) {
                errorDiv.classList.remove('hidden');
                errorMessage.textContent = data.error || 'Error generating code';
                console.error('API Error:', data);
                return;
            }
            
            console.log('Response data:', data); // Log the response for debugging
            
            // Display generated files
            fileContainer.innerHTML = ''; // Clear previous files
            
            if (data.files && Array.isArray(data.files) && data.files.length > 0) {
                // Create file elements
                data.files.forEach(fileData => {
                    if (typeof fileData === 'object' && fileData.filename && fileData.content) {
                        const fileDiv = document.createElement('div');
                        fileDiv.className = 'code-file';
                        
                        const headerDiv = document.createElement('div');
                        headerDiv.className = 'file-header';
                        
                        const filenameSpan = document.createElement('span');
                        filenameSpan.className = 'file-name font-medium';
                        // Use the full path if available, otherwise just the filename
                        const displayName = fileData.path ? `${fileData.path}/${fileData.filename}` : fileData.filename;
                        filenameSpan.textContent = displayName;
                        
                        const copyButton = document.createElement('button');
                        copyButton.className = 'px-2 py-1 text-xs bg-gray-200 hover:bg-gray-300 rounded';
                        copyButton.textContent = 'Copy';
                        copyButton.addEventListener('click', function() {
                            navigator.clipboard.writeText(fileData.content).then(() => {
                                const originalText = copyButton.textContent;
                                copyButton.textContent = 'Copied!';
                                copyButton.classList.add('bg-green-200');
                                
                                setTimeout(() => {
                                    copyButton.textContent = originalText;
                                    copyButton.classList.remove('bg-green-200');
                                }, 2000);
                            });
                        });
                        
                        const contentDiv = document.createElement('div');
                        contentDiv.className = 'file-content';
                        contentDiv.textContent = fileData.content;
                        
                        headerDiv.appendChild(filenameSpan);
                        headerDiv.appendChild(copyButton);
                        
                        fileDiv.appendChild(headerDiv);
                        fileDiv.appendChild(contentDiv);
                        
                        fileContainer.appendChild(fileDiv);
                    }
                });
                
                // Show generated code and copy button
                generatedCodeDiv.classList.remove('hidden');
                copyAllButton.classList.remove('hidden');
            } else {
                errorDiv.classList.remove('hidden');
                errorMessage.textContent = 'No files were generated';
                console.warn('No files in response:', data);
            }
        })
        .catch(error => {
            loadingDiv.classList.add('hidden');
            errorDiv.classList.remove('hidden');
            errorMessage.textContent = 'Network error: ' + error.message;
            console.error('Error details:', error);
        });
    });
});
</script>
{% endblock %} 
