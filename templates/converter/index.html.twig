{% extends 'base.html.twig' %}

{% block title %}{{ 'converter.title'|trans }} - UML2Code{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-indigo-500 to-purple-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-2xl font-bold text-white">{{ 'converter.title'|trans }}</h1>
                    <p class="text-indigo-100 text-sm mt-1">{{ 'converter.subtitle'|trans }}</p>
                </div>
                <button onclick="window.HistoryManager && window.HistoryManager.open('converter')" class="bg-white bg-opacity-20 hover:bg-opacity-30 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors">
                    <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    {{ 'history.button'|trans }}
                </button>
            </div>
        </div>

        <!-- Content -->
        <div class="p-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Input Section -->
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <label class="block text-sm font-medium text-gray-700">
                                {{ 'converter.input_label'|trans }}
                            </label>
                            <button id="import-puml-btn" class="text-sm text-indigo-600 hover:text-indigo-500 flex items-center">
                                <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                                </svg>
                                Import PUML File
                            </button>
                        </div>
                        <div id="uml-editor" class="border border-gray-300 rounded-md" style="height: 400px;"></div>
                        <input type="file" id="puml-file-input" accept=".puml,.plantuml,.txt" class="hidden">
                    </div>

                    <!-- Language Selection -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="language" class="block text-sm font-medium text-gray-700 mb-1">
                                {{ 'converter.language'|trans }}
                            </label>
                            <select id="language" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
                                <option value="">{{ 'converter.select_language'|trans }}</option>
                                {% for language, versions in supported_languages %}
                                    <option value="{{ language }}">{{ language }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div>
                            <label for="version" class="block text-sm font-medium text-gray-700 mb-1">
                                {{ 'converter.version'|trans }}
                            </label>
                            <select id="version" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
                                <option value="">{{ 'converter.select_version'|trans }}</option>
                            </select>
                        </div>
                    </div>

                    <!-- Convert Button -->
                    <button id="convert-btn" class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-200 flex items-center justify-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        {{ 'converter.convert_button'|trans }}
                    </button>
                </div>

                <!-- Output Section -->
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <label class="block text-sm font-medium text-gray-700">
                                {{ 'converter.output_label'|trans }}
                            </label>
                            <div class="flex items-center">
                                <button id="copy-all-btn" class="text-sm text-indigo-600 hover:text-indigo-500 hidden">
                                    {{ 'common.copy'|trans }}
                                </button>
                                <button id="download-all-btn" class="text-sm text-indigo-600 hover:text-indigo-500 hidden ml-4">
                                    {{ 'common.download_all'|trans }}
                                </button>
                            </div>
                        </div>
                        <div id="output-container" class="border border-gray-300 rounded-md bg-gray-50 p-4" style="min-height: 400px;">
                            <div id="output-placeholder" class="text-gray-500 text-center">
                                {{ 'converter.output_placeholder'|trans }}
                            </div>
                            <div id="output-loading" class="hidden">
                                <div class="flex justify-center items-center h-full">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
                                </div>
                            </div>
                            <div id="output-files" class="hidden space-y-4"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Error Alert -->
            <div id="error-alert" class="mt-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md hidden">
                <div class="flex">
                    <svg class="h-5 w-5 text-red-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                    </svg>
                    <span id="error-message"></span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
require([
    'vs/editor/editor.main',
    'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js'
], function(_, JSZip) {
    // Wait for PlantUML registration before creating editor
    function createUMLEditor() {
        if (window.isPlantUMLRegistered && window.isPlantUMLRegistered()) {
            const currentTheme = localStorage.getItem("theme") === "dark" ? "dark" : "light";
            const plantumlTheme = window.getPlantUMLTheme ? window.getPlantUMLTheme(currentTheme === "dark") : 
                                 (currentTheme === "dark" ? 'plantuml-dark' : 'plantuml-light');
            
            // Initialize UML editor with PlantUML syntax highlighting
            const umlEditor = monaco.editor.create(document.getElementById('uml-editor'), {
                value: `@startuml
class User {
    -id: int
    -email: string  
    -password: string
    +login(email: string, password: string): bool
    +logout(): void
}

class Order {
    -id: int
    -userId: int
    -total: float
    -status: string
    +calculateTotal(): float
    +updateStatus(status: string): void
}

User "1" --> "*" Order : places
@enduml`,
                language: 'plantuml',
                theme: plantumlTheme,
                minimap: { enabled: false },
                automaticLayout: true,
                fontSize: 13,
                lineNumbers: 'on',
                wordWrap: 'on'
            });
            
            // Store editor reference for theme updates
            window.umlEditor = umlEditor;
            
            initializeEventHandlers();
        } else {
            // Retry after a short delay
            setTimeout(createUMLEditor, 100);
        }
    }
    
    function initializeEventHandlers() {
        // Language versions mapping
        const languageVersions = {
            {% for language, versions in supported_languages %}
                "{{ language }}": {{ versions|json_encode|raw }},
            {% endfor %}
        };

    // Handle PUML file import
    const importBtn = document.getElementById('import-puml-btn');
    const fileInput = document.getElementById('puml-file-input');
    
    importBtn.addEventListener('click', function() {
        fileInput.click();
    });
    
    fileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            // Check file extension
            const validExtensions = ['.puml', '.plantuml', '.txt'];
            const fileExtension = file.name.toLowerCase().substring(file.name.lastIndexOf('.'));
            
            if (!validExtensions.includes(fileExtension)) {
                showError('Please select a valid PlantUML file (.puml, .plantuml, or .txt)');
                return;
            }
            
            // Check file size (max 1MB)
            if (file.size > 1024 * 1024) {
                showError('File size must be less than 1MB');
                return;
            }
            
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const content = e.target.result;
                    // Set the content in the Monaco editor
                    window.umlEditor.setValue(content);
                    
                    // Clear any errors
                    hideError();
                    
                    // Show success feedback
                    const originalText = importBtn.textContent;
                    importBtn.innerHTML = '<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>File Imported!';
                    importBtn.classList.add('text-green-600');
                    
                    setTimeout(() => {
                        importBtn.innerHTML = '<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path></svg>Import PUML File';
                        importBtn.classList.remove('text-green-600');
                    }, 2000);
                    
                } catch (error) {
                    showError('Error reading file: ' + error.message);
                }
            };
            
            reader.onerror = function() {
                showError('Error reading file');
            };
            
            reader.readAsText(file);
        }
        
        // Reset file input
        fileInput.value = '';
    });

    // Handle language selection
    document.getElementById('language').addEventListener('change', function(e) {
        const language = e.target.value;
        const versionSelect = document.getElementById('version');
        
        // Clear versions
        versionSelect.innerHTML = '<option value="">{{ 'converter.select_version'|trans }}</option>';
        
        if (language && languageVersions[language]) {
            languageVersions[language].forEach(version => {
                const option = document.createElement('option');
                option.value = version;
                option.textContent = version;
                versionSelect.appendChild(option);
            });
            
            // Auto-select first version
            if (languageVersions[language].length > 0) {
                versionSelect.value = languageVersions[language][0];
            }
        }
    });

    // Convert function
    document.getElementById('convert-btn').addEventListener('click', async function() {
        const uml = umlEditor.getValue();
        const language = document.getElementById('language').value;
        const version = document.getElementById('version').value;

        if (!uml.trim()) {
            showError('{{ 'converter.error.empty_uml'|trans }}');
            return;
        }

        if (!language) {
            showError('{{ 'converter.error.no_language'|trans }}');
            return;
        }

        // Show loading
        document.getElementById('output-placeholder').classList.add('hidden');
        document.getElementById('output-loading').classList.remove('hidden');
        document.getElementById('output-files').classList.add('hidden');
        document.getElementById('copy-all-btn').classList.add('hidden');
        document.getElementById('download-all-btn').classList.add('hidden');
        hideError();

        try {
            const response = await fetch('/api/converter/convert', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    uml: uml,
                    language: language,
                    version: version
                })
            });

            const data = await response.json();

            if (!response.ok || !data.success) {
                throw new Error(data.error || '{{ 'converter.error.conversion_failed'|trans }}');
            }

            displayFiles(data.files);
        } catch (error) {
            showError(error.message);
            document.getElementById('output-loading').classList.add('hidden');
            document.getElementById('output-placeholder').classList.remove('hidden');
        }
    });

    // Display generated files
    function displayFiles(files) {
        const container = document.getElementById('output-files');
        container.innerHTML = '';

        files.forEach((file, index) => {
            const fileDiv = document.createElement('div');
            fileDiv.className = 'bg-white rounded-md border border-gray-200 overflow-hidden';
            fileDiv.innerHTML = `
                <div class="bg-gray-50 px-4 py-2 border-b border-gray-200 flex justify-between items-center">
                    <span class="font-medium text-sm text-gray-700">${file.filename}</span>
                    <div>
                        <button class="text-sm text-indigo-600 hover:text-indigo-500 mr-2" onclick="copyFile(${index}, this)">
                            {{ 'common.copy'|trans }}
                        </button>
                        <button class="text-sm text-indigo-600 hover:text-indigo-500" onclick="downloadFile(${index})">
                            {{ 'common.download'|trans }}
                        </button>
                    </div>
                </div>
                <div id="file-editor-${index}" class="file-editor" style="height: 300px;"></div>
            `;
            container.appendChild(fileDiv);

            // Create editor for file
            setTimeout(() => {
                monaco.editor.create(document.getElementById(`file-editor-${index}`), {
                    value: file.content,
                    language: getMonacoLanguage(file.filename),
                    theme: window.monacoTheme,
                    readOnly: true,
                    minimap: { enabled: false },
                    automaticLayout: true,
                    fontSize: 13,
                    lineNumbers: 'on',
                    wordWrap: 'on'
                });
            }, 100);
        });

        // Store files globally for copy functionality
        window.generatedFiles = files;

        document.getElementById('output-loading').classList.add('hidden');
        document.getElementById('output-files').classList.remove('hidden');
        document.getElementById('copy-all-btn').classList.remove('hidden');
        document.getElementById('download-all-btn').classList.remove('hidden');
    }

    // Get Monaco language from filename
    function getMonacoLanguage(filename) {
        if (filename.endsWith('.php')) return 'php';
        if (filename.endsWith('.java')) return 'java';
        if (filename.endsWith('.js')) return 'javascript';
        if (filename.endsWith('.py')) return 'python';
        if (filename.endsWith('.cs')) return 'csharp';
        if (filename.endsWith('.ts')) return 'typescript';
        if (filename.endsWith('.js')) return 'javascript';
        return 'plaintext';
    }

    // Copy file content
    window.copyFile = function(index, buttonElement) {
        if (window.generatedFiles && window.generatedFiles[index]) {
            navigator.clipboard.writeText(window.generatedFiles[index].content).then(() => {
                const originalText = buttonElement.textContent;
                buttonElement.textContent = '{{ 'common.copied'|trans }}';
                buttonElement.classList.add('text-green-600');
                setTimeout(() => {
                    buttonElement.textContent = originalText;
                    buttonElement.classList.remove('text-green-600');
                }, 2000);
            });
        }
    };

    // Copy all files
    document.getElementById('copy-all-btn').addEventListener('click', function() {
        if (window.generatedFiles) {
            const allContent = window.generatedFiles.map(f => 
                `// ${f.filename}\n${f.content}`
            ).join('\n\n');
            
            navigator.clipboard.writeText(allContent).then(() => {
                const btn = this;
                const originalText = btn.textContent;
                btn.textContent = '{{ 'common.copied'|trans }}';
                btn.classList.add('text-green-600');
                setTimeout(() => {
                    btn.textContent = originalText;
                    btn.classList.remove('text-green-600');
                }, 2000);
            });
        }
    });

    // Download file
    window.downloadFile = function(index) {
        if (window.generatedFiles && window.generatedFiles[index]) {
            const file = window.generatedFiles[index];
            const blob = new Blob([file.content], { type: 'text/plain' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = file.filename;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
    };

    // Download all files
    document.getElementById('download-all-btn').addEventListener('click', function() {
        if (window.generatedFiles) {
            const zip = new JSZip();
            window.generatedFiles.forEach(file => {
                zip.file(file.filename, file.content);
            });
            zip.generateAsync({ type: 'blob' }).then(function(content) {
                const link = document.createElement('a');
                link.href = URL.createObjectURL(content);
                link.download = 'generated_code.zip';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        }
    });

    // Error handling
    function showError(message) {
        document.getElementById('error-message').textContent = message;
        document.getElementById('error-alert').classList.remove('hidden');
    }

    function hideError() {
        document.getElementById('error-alert').classList.add('hidden');
    }
    
    } // End of initializeEventHandlers function
    
    // Start the initialization process
    createUMLEditor();
});
</script>
{% endblock %}
