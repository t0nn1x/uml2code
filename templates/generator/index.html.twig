{% extends 'base.html.twig' %}

{% block title %}{{ 'generator.title'|trans }} - UML2Code{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-white shadow-lg rounded-lg overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-indigo-500 to-purple-600 px-6 py-4">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-2xl font-bold text-white">{{ 'generator.title'|trans }}</h1>
                    <p class="text-indigo-100 text-sm mt-1">{{ 'generator.subtitle'|trans }}</p>
                </div>
                <button onclick="window.HistoryManager && window.HistoryManager.open('generator')" class="bg-white bg-opacity-20 hover:bg-opacity-30 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors">
                    <svg class="w-5 h-5 inline mr-1" fill="none" stroke="currentColor" viewbox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    {{ 'history.button'|trans }}
                </button>
            </div>
        </div>

        <!-- Content -->
        <div class="p-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Input Section -->
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <label class="block text-sm font-medium text-gray-700">
                                {{ 'generator.input_label'|trans }}
                            </label>
                                                    <button id="import-json-btn" class="text-sm text-indigo-600 hover:text-indigo-500 flex items-center">
                            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path>
                            </svg>
                            {{ 'common.import_json_file'|trans }}
                        </button>
                        </div>
                        <div id="json-editor" class="border border-gray-300 rounded-md" style="height: 400px;"></div>
                        <input type="file" id="json-file-input" accept=".json,.txt" class="hidden">
                    </div>

                    <!-- Language Selection -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label for="language-select" class="block text-sm font-medium text-gray-700 mb-1">
                                {{ 'generator.language'|trans }}
                            </label>
                            <select id="language-select" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
                                <option value="">{{ 'generator.select_language'|trans }}</option>
                                {% for language, versions in supported_languages %}
                                    <option value="{{ language }}">{{ language }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div>
                            <label for="version-select" class="block text-sm font-medium text-gray-700 mb-1">
                                {{ 'generator.version'|trans }}
                            </label>
                            <select id="version-select" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
                                <option value="">{{ 'generator.select_version'|trans }}</option>
                            </select>
                        </div>
                    </div>

                    <!-- Generate Button -->
                    <button id="generate-button" class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 transition duration-200 flex items-center justify-center">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                        {{ 'generator.generate_button'|trans }}
                    </button>
                </div>

                <!-- Output Section -->
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between items-center mb-2">
                            <label class="block text-sm font-medium text-gray-700">
                                {{ 'generator.output_label'|trans }}
                            </label>
                            <div class="flex items-center">
                                <button id="copy-all-button" class="text-sm text-indigo-600 hover:text-indigo-500 hidden">
                                    {{ 'common.copy'|trans }}
                                </button>
                                <button id="download-all-btn" class="text-sm text-indigo-600 hover:text-indigo-500 hidden ml-4">
                                    {{ 'common.download_all'|trans }}
                                </button>
                            </div>
                        </div>
                        <div id="output-container" class="border border-gray-300 rounded-md bg-gray-50 p-4" style="min-height: 400px;">
                            <div id="output-placeholder" class="text-gray-500 text-center">
                                {{ 'generator.output_placeholder'|trans }}
                            </div>
                            <div id="loading" class="hidden">
                                <div class="flex justify-center items-center h-full">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-indigo-600"></div>
                                </div>
                            </div>
                            <div id="generated-code" class="hidden space-y-4">
                                <div id="file-container" class="space-y-4"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Error Alert -->
            <div id="error" class="mt-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-md hidden">
                <div class="flex">
                    <svg class="h-5 w-5 text-red-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                    </svg>
                    <span id="error-message"></span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
require([
    'vs/editor/editor.main',
    'https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js'
], function(_, JSZip) {
    const generateButton = document.getElementById('generate-button');
    const jsonEditor = document.getElementById('json-editor');
    const loadingDiv = document.getElementById('loading');
    const errorDiv = document.getElementById('error');
    const errorMessage = document.getElementById('error-message');
    const copyAllButton = document.getElementById('copy-all-button');
    const languageSelect = document.getElementById('language-select');
    const versionSelect = document.getElementById('version-select');
    const generatedCodeDiv = document.getElementById('generated-code');
    const fileContainer = document.getElementById('file-container');
    const outputPlaceholder = document.getElementById('output-placeholder');
    const outputContainer = document.getElementById('output-container');

    // Store the supported languages
    const supportedLanguages = {
        {% for language, versions in supported_languages %}
            "{{ language }}": {{ versions|json_encode|raw }},
        {% endfor %}
    };

    // Add event listener for language selection
    languageSelect.addEventListener('change', function() {
        const language = this.value;
        versionSelect.innerHTML = '<option value="">{{ 'generator.select_version'|trans }}</option>';
        if (language && supportedLanguages[language]) {
            supportedLanguages[language].forEach(version => {
                const option = document.createElement('option');
                option.value = version;
                option.textContent = version;
                versionSelect.appendChild(option);
            });
            if (supportedLanguages[language].length > 0) {
                versionSelect.value = supportedLanguages[language][0];
            }
        }
    });

    // Copy all generated code
    copyAllButton.addEventListener('click', function() {
        if (window.generatedFiles) {
            const allContent = window.generatedFiles.map(f => 
                `// ${f.filename}\n${f.content}`
            ).join('\n\n');
            navigator.clipboard.writeText(allContent).then(() => {
                const originalText = copyAllButton.textContent;
                copyAllButton.textContent = '{{ 'common.copied'|trans }}';
                copyAllButton.classList.add('text-green-600');
                setTimeout(() => {
                    copyAllButton.textContent = originalText;
                    copyAllButton.classList.remove('text-green-600');
                }, 2000);
            });
        }
    });

    // Download all files as ZIP
    const downloadAllBtn = document.getElementById('download-all-btn');
    downloadAllBtn.addEventListener('click', function() {
        if (window.generatedFiles) {
            const zip = new JSZip();
            window.generatedFiles.forEach(file => {
                zip.file(file.filename, file.content);
            });
            zip.generateAsync({ type: 'blob' }).then(function(content) {
                const link = document.createElement('a');
                link.href = URL.createObjectURL(content);
                link.download = 'generated_code.zip';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
            });
        }
    });

    // Initialize JSON editor
    const jsonExample = `{
    "classes": [
      {
        "name": "User",
        "type": "class",
        "attributes": [
          {
            "name": "id",
            "visibility": "public",
            "type": "int"
          },
          {
            "name": "password",
            "visibility": "private",
            "type": "string"
          }
        ],
        "methods": [
          {
            "name": "login",
            "visibility": "public",
            "parameters": [
              {
                "name": "password",
                "type": "string"
              }
            ],
            "returnType": "bool"
          }
        ]
      },
      {
        "name": "Order",
        "type": "class",
        "attributes": [
          {
            "name": "id",
            "visibility": "public",
            "type": "int"
          },
          {
            "name": "date",
            "visibility": "public",
            "type": "DateTime"
          }
        ],
        "methods": [
          {
            "name": "calculateTotal",
            "visibility": "public",
            "parameters": [],
            "returnType": "float"
          }
        ]
      }
    ],
    "relationships": [
      {
        "source": "User",
        "target": "Order",
        "type": "association",
        "label": "places",
        "sourceMultiplicity": "1",
        "targetMultiplicity": "*"
      }
    ]
}`;
    const jsonEditorInstance = monaco.editor.create(document.getElementById('json-editor'), {
        value: jsonExample,
        language: 'json',
        theme: window.monacoTheme,
        minimap: { enabled: false },
        automaticLayout: true,
        fontSize: 13,
        lineNumbers: 'on',
        wordWrap: 'on'
    });

    // Handle JSON file import
    const importJsonBtn = document.getElementById('import-json-btn');
    const jsonFileInput = document.getElementById('json-file-input');
    
    importJsonBtn.addEventListener('click', function() {
        jsonFileInput.click();
    });
    
    jsonFileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            // Check file extension
            const validExtensions = ['.json', '.txt'];
            const fileExtension = file.name.toLowerCase().substring(file.name.lastIndexOf('.'));
            
            if (!validExtensions.includes(fileExtension)) {
                showError('{{ 'import.error.invalid_json_file'|trans }}');
                return;
            }
            
            // Check file size (max 1MB)
            if (file.size > 1024 * 1024) {
                showError('{{ 'import.error.file_too_large'|trans }}');
                return;
            }
            
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const content = e.target.result;
                    
                    // Validate JSON syntax
                    try {
                        JSON.parse(content);
                    } catch (jsonError) {
                        showError('{{ 'import.error.invalid_json_syntax'|trans }}: ' + jsonError.message);
                        return;
                    }
                    
                    // Set the content in the Monaco editor
                    jsonEditorInstance.setValue(content);
                    
                    // Clear any errors
                    hideError();
                    
                    // Show success feedback
                    const originalText = importJsonBtn.textContent;
                    importJsonBtn.innerHTML = '<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>{{ 'common.file_imported'|trans }}';
                    importJsonBtn.classList.add('text-green-600');
                    
                    setTimeout(() => {
                        importJsonBtn.innerHTML = '<svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"></path></svg>{{ 'common.import_json_file'|trans }}';
                        importJsonBtn.classList.remove('text-green-600');
                    }, 2000);
                    
                } catch (error) {
                    showError('{{ 'import.error.read_error'|trans }}: ' + error.message);
                }
            };
            
            reader.onerror = function() {
                showError('{{ 'import.error.read_error'|trans }}');
            };
            
            reader.readAsText(file);
        }
        
        // Reset file input
        jsonFileInput.value = '';
    });

    // Generate code
    generateButton.addEventListener('click', function() {
        const jsonCode = jsonEditorInstance.getValue().trim();
        const language = languageSelect.value;
        const version = versionSelect.value;
        if (!jsonCode) {
            showError('{{ 'generator.error.empty_json'|trans }}');
            return;
        }
        if (!language) {
            showError('{{ 'generator.error.no_language'|trans }}');
            return;
        }
        // Validate JSON
        let parsedJson;
        try {
            parsedJson = JSON.parse(jsonCode);
        } catch (e) {
            showError('{{ 'generator.error.invalid_json'|trans }}: ' + e.message);
            return;
        }
        // Show loading, hide errors
        outputPlaceholder.classList.add('hidden');
        loadingDiv.classList.remove('hidden');
        generatedCodeDiv.classList.add('hidden');
        copyAllButton.classList.add('hidden');
        downloadAllBtn.classList.add('hidden');
        hideError();
        // Make API request to generate code
        fetch('/api/generator/generate', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                diagram: parsedJson,
                language: language,
                version: version
            })
        })
        .then(response => {
            if (!response.ok) {
                throw new Error(`HTTP error! Status: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            loadingDiv.classList.add('hidden');
            if (data.success === false) {
                showError(data.error || '{{ 'generator.error.generation_failed'|trans }}');
                outputPlaceholder.classList.remove('hidden');
                return;
            }
            // Display generated files
            fileContainer.innerHTML = '';
            if (data.files && Array.isArray(data.files) && data.files.length > 0) {
                data.files.forEach((fileData, index) => {
                    if (typeof fileData === 'object' && fileData.filename && fileData.content) {
                        const fileDiv = document.createElement('div');
                        fileDiv.className = 'code-file bg-white rounded-md border border-gray-200 overflow-hidden';
                        fileDiv.innerHTML = `
                            <div class="bg-gray-50 px-4 py-2 border-b border-gray-200 flex justify-between items-center">
                                <span class="file-name font-medium text-sm text-gray-700">${fileData.filename}</span>
                                <div>
                                    <button class="text-sm text-indigo-600 hover:text-indigo-500 mr-2" onclick="copyFile(${index}, this)">
                                        {{ 'common.copy'|trans }}
                                    </button>
                                    <button class="text-sm text-indigo-600 hover:text-indigo-500" onclick="downloadFile(${index})">
                                        {{ 'common.download'|trans }}
                                    </button>
                                </div>
                            </div>
                            <div id="file-editor-${index}" class="file-editor" style="height: 300px;"></div>
                        `;
                        fileContainer.appendChild(fileDiv);
                        // Create Monaco editor for file
                        setTimeout(() => {
                            monaco.editor.create(document.getElementById(`file-editor-${index}`), {
                                value: fileData.content,
                                language: getMonacoLanguage(fileData.filename),
                                theme: window.monacoTheme,
                                readOnly: true,
                                minimap: { enabled: false },
                                automaticLayout: true,
                                fontSize: 13,
                                lineNumbers: 'on',
                                wordWrap: 'on'
                            });
                        }, 100);
                    }
                });
                window.generatedFiles = data.files;
                generatedCodeDiv.classList.remove('hidden');
                copyAllButton.classList.remove('hidden');
                downloadAllBtn.classList.remove('hidden');
            } else {
                showError('No files were generated');
                outputPlaceholder.classList.remove('hidden');
                downloadAllBtn.classList.add('hidden');
            }
        })
        .catch(error => {
            loadingDiv.classList.add('hidden');
            showError('Network error: ' + error.message);
            outputPlaceholder.classList.remove('hidden');
        });
    });

    // Get Monaco language from filename
    function getMonacoLanguage(filename) {
        if (filename.endsWith('.php')) return 'php';
        if (filename.endsWith('.java')) return 'java';
        if (filename.endsWith('.js')) return 'javascript';
        if (filename.endsWith('.py')) return 'python';
        if (filename.endsWith('.cs')) return 'csharp';
        return 'plaintext';
    }

    // Copy file content
    window.copyFile = function(index, buttonElement) {
        if (window.generatedFiles && window.generatedFiles[index]) {
            navigator.clipboard.writeText(window.generatedFiles[index].content).then(() => {
                const originalText = buttonElement.textContent;
                buttonElement.textContent = '{{ 'common.copied'|trans }}';
                buttonElement.classList.add('text-green-600');
                setTimeout(() => {
                    buttonElement.textContent = originalText;
                    buttonElement.classList.remove('text-green-600');
                }, 2000);
            });
        }
    };

    // Download file
    window.downloadFile = function(index) {
        if (window.generatedFiles && window.generatedFiles[index]) {
            const file = window.generatedFiles[index];
            const blob = new Blob([file.content], { type: 'text/plain' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = file.filename;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
    };

    // Error handling
    function showError(message) {
        errorMessage.textContent = message;
        errorDiv.classList.remove('hidden');
    }
    function hideError() {
        errorDiv.classList.add('hidden');
    }
});
</script>
{% endblock %}
