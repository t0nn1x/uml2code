{% extends 'base.html.twig' %}

{% block title %}Code Generator - UML2Code{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&display=swap">
    <style>
        .json-editor {
            min-height: 300px;
            font-family: 'IBM Plex Mono', 'Courier New', monospace;
            resize: vertical;
            font-size: 14px;
            line-height: 1.5;
            padding: 12px;
        }

        .results {
            max-height: 500px;
            overflow-y: auto;
        }

        .code-block {
            background-color: #fff;
            border: 1px solid #e5e7eb;
            border-radius: 6px;
            margin-bottom: 1rem;
        }

        .code-header {
            display: flex;
            align-items: center;
            padding: 8px 12px;
            background-color: #f9fafb;
            border-bottom: 1px solid #e5e7eb;
            border-top-left-radius: 6px;
            border-top-right-radius: 6px;
            font-family: 'IBM Plex Mono', 'Courier New', monospace;
            font-size: 13px;
            color: #4b5563;
        }

        .code-header svg {
            margin-right: 8px;
            color: #6b7280;
        }

        .code-content {
            font-family: 'IBM Plex Mono', 'Courier New', monospace !important;
            white-space: pre;
            tab-size: 4;
            -moz-tab-size: 4;
            padding: 16px;
            margin: 0;
            font-size: 14px;
            line-height: 1.6;
            overflow-x: auto;
            background-color: #fff;
            border-bottom-left-radius: 6px;
            border-bottom-right-radius: 6px;
        }

        /* Scrollbar styling */
        .code-content::-webkit-scrollbar {
            height: 8px;
        }

        .code-content::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 4px;
        }

        .code-content::-webkit-scrollbar-thumb {
            background: #d1d5db;
            border-radius: 4px;
        }

        .code-content::-webkit-scrollbar-thumb:hover {
            background: #9ca3af;
        }

        /* Firefox scrollbar */
        .code-content {
            scrollbar-width: thin;
            scrollbar-color: #d1d5db #f1f1f1;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="min-h-screen flex flex-col bg-gray-100">
        <header class="bg-white shadow">
            <div class="max-w-7xl mx-auto py-6 px-4 sm:px-6 lg:px-8">
                <h1 class="text-3xl font-bold text-gray-900">Code Generator</h1>
            </div>
        </header>

        <main class="flex-grow">
            <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
                <div class="px-4 py-6 sm:px-0">
                    <div class="bg-white overflow-hidden shadow rounded-lg divide-y divide-gray-200">
                        <div class="px-4 py-5 sm:p-6">
                            <div class="mb-4">
                                <label for="language" class="block text-sm font-medium text-gray-700">Target Language</label>
                                <select id="language" class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md">
                                    {% for language, versions in supported_languages %}
                                        {% for version in versions %}
                                            <option value="{{ language }}" data-version="{{ version }}">{{ language }} {{ version }}</option>
                                        {% endfor %}
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="mb-4">
                                <label for="diagram" class="block text-sm font-medium text-gray-700">UML Diagram (JSON)</label>
                                <textarea id="diagram" class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm p-2 json-editor" rows="10" placeholder="Paste your UML JSON here..."></textarea>
                            </div>

                            <div class="flex justify-end">
                                <button id="generate-btn" type="button" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                                    Generate Code
                                </button>
                            </div>
                        </div>

                        <div class="px-4 py-5 sm:p-6">
                            <div class="flex justify-between items-center">
                                <h3 class="text-lg font-medium leading-6 text-gray-900">Generated Code</h3>
                                <button id="copy-button" type="button" class="inline-flex items-center px-3 py-1 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 hidden">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                                    </svg>
                                    Copy Code
                                </button>
                            </div>
                            <div id="loading" class="mt-4 hidden">
                                <div class="flex justify-center">
                                    <svg class="animate-spin h-5 w-5 text-indigo-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                    <span class="ml-2">Generating code...</span>
                                </div>
                            </div>
                            <div id="error" class="mt-4 bg-red-50 p-4 rounded-md hidden">
                                <div class="flex">
                                    <div class="flex-shrink-0">
                                        <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewbox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <h3 class="text-sm font-medium text-red-800" id="error-message">Error generating code</h3>
                                    </div>
                                </div>
                            </div>
                            <div id="output-area" class="mt-4 bg-gray-50 rounded-md results hidden">
                                <p class="text-muted p-4">Generated code will appear here</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const generateBtn = document.getElementById('generate-btn');
    const diagramInput = document.getElementById('diagram');
    const languageSelect = document.getElementById('language');
    const outputArea = document.getElementById('output-area');
    const loadingDiv = document.getElementById('loading');
    const errorDiv = document.getElementById('error');
    const errorMessage = document.getElementById('error-message');
    const copyButton = document.getElementById('copy-button');

    function escapeHtml(unsafe) {
        return unsafe
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&#039;");
    }

    // Copy button functionality
    copyButton.addEventListener('click', function() {
        const codeBlocks = outputArea.querySelectorAll('.code-content');
        let textToCopy = '';
        
        codeBlocks.forEach(block => {
            textToCopy += block.textContent + '\n\n';
        });
        
        navigator.clipboard.writeText(textToCopy).then(() => {
            const originalText = copyButton.innerHTML;
            copyButton.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Copied!
            `;
            copyButton.classList.remove('text-gray-700', 'bg-white', 'hover:bg-gray-50');
            copyButton.classList.add('text-green-700', 'bg-green-50', 'hover:bg-green-100');
            
            setTimeout(() => {
                copyButton.innerHTML = originalText;
                copyButton.classList.remove('text-green-700', 'bg-green-50', 'hover:bg-green-100');
                copyButton.classList.add('text-gray-700', 'bg-white', 'hover:bg-gray-50');
            }, 2000);
        }).catch(err => {
            console.error('Failed to copy text: ', err);
        });
    });

    generateBtn.addEventListener('click', function() {
        const diagramData = diagramInput.value.trim();
        if (!diagramData) {
            errorDiv.classList.remove('hidden');
            errorMessage.textContent = 'Please enter diagram data';
            outputArea.classList.add('hidden');
            copyButton.classList.add('hidden');
            return;
        }

        let diagram;
        try {
            diagram = JSON.parse(diagramData);
        } catch (e) {
            errorDiv.classList.remove('hidden');
            errorMessage.textContent = 'Invalid JSON: ' + e.message;
            outputArea.classList.add('hidden');
            copyButton.classList.add('hidden');
            return;
        }

        loadingDiv.classList.remove('hidden');
        outputArea.classList.add('hidden');
        errorDiv.classList.add('hidden');
        copyButton.classList.add('hidden');

        const language = languageSelect.value;
        const version = languageSelect.options[languageSelect.selectedIndex].dataset.version;

        fetch('/api/generator/generate', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                diagram: diagram,
                language: language,
                version: version
            })
        })
        .then(response => response.json())
        .then(data => {
            loadingDiv.classList.add('hidden');

            if (data.success) {
                let output = '<div class="space-y-4">';
                data.files.forEach(file => {
                    output += `
                        <div class="code-block">
                            <div class="code-header">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M4 1v14M12 1v14M1 4h14M1 12h14"/>
                                </svg>
                                ${file.path}/${file.filename}
                            </div>
                            <pre class="code-content">${escapeHtml(file.content)}</pre>
                        </div>
                    `;
                });
                output += '</div>';
                
                outputArea.innerHTML = output;
                outputArea.classList.remove('hidden');
                copyButton.classList.remove('hidden');
            } else {
                errorDiv.classList.remove('hidden');
                errorMessage.textContent = data.error;
                
                let errorDetails = '';
                if (data.context) {
                    errorDetails += `<pre class="mt-2 text-sm text-red-700">${JSON.stringify(data.context, null, 2)}</pre>`;
                }
                if (data.trace) {
                    errorDetails += `
                        <details class="mt-2">
                            <summary class="text-sm text-red-700 cursor-pointer">Stack Trace</summary>
                            <pre class="mt-2 text-xs text-red-600">${data.trace}</pre>
                        </details>
                    `;
                }
                errorDiv.querySelector('.ml-3').innerHTML += errorDetails;
            }
        })
        .catch(error => {
            loadingDiv.classList.add('hidden');
            errorDiv.classList.remove('hidden');
            errorMessage.textContent = 'Network error: ' + error.message;
        });
    });
});
</script>
{% endblock %} 
